# ---- HTTP server ----
# 8080 is taken by coolify-proxy on this host; the agent uses 8088.
PORT=8088
LOG_LEVEL=info
# pretty logs in dev (true) vs JSON in prod (false)
LOG_PRETTY=true

# ---- GitHub App ----
# Numeric App ID from the GitHub App settings page.
GITHUB_APP_ID=
# The app private key (PEM). Either inline (with literal \n) OR point to a file via GITHUB_PRIVATE_KEY_PATH.
GITHUB_PRIVATE_KEY=
GITHUB_PRIVATE_KEY_PATH=
# Webhook secret configured on the GitHub App.
GITHUB_WEBHOOK_SECRET=

# ---- oMLX (OpenAI-compatible) ----
# oMLX (MLX-based local model server) runs on a separate Mac host on the LAN.
# Unlike the old LM Studio backend, oMLX REQUIRES an API key (Bearer token); set it below.
LMSTUDIO_BASE_URL=http://192.168.4.38:1234/v1
LMSTUDIO_API_KEY=omlx-xxxxxxxxxxxxxxxx
# Exact oMLX model ids as returned by GET /v1/models (auth required). One model is used
# for everything for now; verify with:
#   curl -H "Authorization: Bearer $LMSTUDIO_API_KEY" http://192.168.4.38:1234/v1/models
MODEL_CODE=Qwen3.6-35B-A3B-MLX-8bit
MODEL_DEBUG=Qwen3.6-35B-A3B-MLX-8bit
# "Pro" model. Used for EVERYTHING on issues labeled ai-dev-pro, and for coding
# fixes after the first failed CI try (escalation). Currently the same single oMLX
# coding model; point at a larger/different oMLX id here if you add one.
MODEL_PRO=Qwen3.6-35B-A3B-MLX-8bit
# Coding tasks escalate to MODEL_PRO once attempt >= this (0 = initial implement,
# so 1 means the first CI-failure fix and onward use MODEL_PRO).
ESCALATE_AFTER_RETRIES=1
# Per-request timeout (ms). First call to a cold (JIT) model can be slow.
LLM_TIMEOUT_MS=600000
# Output cap per LLM response. Raised to 16384 as a safety net so large single-file
# creates don't get truncated (finish_reason "length"); surgical @@EDIT blocks keep
# normal modify responses small.
LLM_MAX_OUTPUT_TOKENS=16384
# JIT auto-unload TTL (seconds) sent with each request so the idle model is
# evicted and qwen + deepseek are not both resident at once. 0 disables it.
LLM_TTL_SECONDS=900
# Eject-before-load: before each LLM call, unload any OTHER model currently resident
# in LM Studio (POST {host}/api/v1/models/unload) so only the target model is loaded
# — true one-model-at-a-time, never two big models in VRAM at once. Best-effort and
# non-fatal (failures are ignored). Set false to disable.
EJECT_OTHER_MODELS=true
# How many repo files to feed the model as context per implement step.
IMPLEMENT_CONTEXT_FILES=40
# Per-file byte cap for implement context. Keep this LARGE so the model sees the
# FULL content of files it edits — surgical @@EDIT needs exact SEARCH anchors, and a
# truncated file means the model can't copy unseen regions verbatim. 200000 ~= 50k
# tokens, enough for a 55KB single-file app. Truly huge files are still truncated
# (with a notice telling the model to use a full @@FILE rewrite instead of @@EDIT).
IMPLEMENT_MAX_FILE_BYTES=200000

# ---- Agent behaviour ----
# Absolute path where repos are cloned/cached.
WORKDIR=/home/opti3/services/ai-dev/data/repos
# SQLite database file.
DB_PATH=/home/opti3/services/ai-dev/data/agent.db
# Comma-separated allowlist the agent may act on. Empty = allow none (safe default).
# Entry forms: "owner/repo" (exact), "owner/*" or "owner" (all repos under an org/user).
REPO_ALLOWLIST=
# Only act on issues carrying this label. Empty = act on every newly opened issue.
TRIGGER_LABEL=ai-dev
# Pro label: also triggers the agent, and forces MODEL_PRO for the entire run.
PRO_LABEL=ai-dev-pro
# Only these GitHub logins (the actor who applies the label / opens the issue) may
# trigger the agent. Comma-separated, case-insensitive. Empty = anyone.
TRIGGER_USERS=
# Big "epic" tasks: per-step commits + pro model + feature-flagged + left for manual
# review (no auto-merge). Also a trigger label.
EPIC_LABEL=ai-dev-epic
EPIC_MAX_STEPS=20
# Allow the agent to create/modify GitHub Actions workflow files (.github/workflows/*).
# Default false: the agent has authored broken/inappropriate CI (e.g. an npm build/deploy
# pipeline for a static single-file site), so such edits are DROPPED and noted on the PR.
# When true, each workflow edit's resulting content is validated as YAML + Actions shape
# (must have top-level `on` and `jobs`) before being committed; invalid ones are dropped.
ALLOW_WORKFLOW_EDITS=false
MAX_RETRIES=5
AUTO_MERGE=true
# Don't auto-merge a no-CI PR whose net deletions exceed this (avoids silently
# merging destructive changes). 0 disables the guard.
AUTO_MERGE_MAX_NET_DELETIONS=200
# squash | merge | rebase
MERGE_METHOD=squash
BRANCH_PREFIX=feature/issue-

# Git identity used for commits made by the agent.
GIT_AUTHOR_NAME=ai-dev-bot
GIT_AUTHOR_EMAIL=ai-dev-bot@users.noreply.github.com

# ---- CI polling fallback ----
# Poll interval for workflow runs when webhook delivery is missed (ms). 0 disables polling.
CI_POLL_INTERVAL_MS=30000
# Max time to wait for a workflow run to appear/complete before giving up (ms).
CI_WAIT_TIMEOUT_MS=1800000
# Grace period before concluding a commit has no CI at all (ms).
CI_GRACE_MS=90000
# When a repo has NO CI run/check for the commit and GitHub reports the PR
# mergeable/clean, auto-merge it instead of waiting (true). Real CI still gates.
MERGE_WITHOUT_CI=true

# ---- Optional Coolify deploy hook ----
# POSTed after a successful auto-merge. Empty disables it.
COOLIFY_DEPLOY_HOOK_URL=
