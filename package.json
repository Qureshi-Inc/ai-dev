{
  "name": "ai-dev-orchestrator",
  "version": "0.1.0",
  "private": true,
  "description": "Autonomous coding agent: GitHub issues -> tested, auto-merged PRs via LM Studio (Qwen + DeepSeek).",
  "type": "module",
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "smoke": "tsx scripts/smoke.ts"
  },
  "dependencies": {
    "@octokit/app": "^16.1.2",
    "@octokit/rest": "^22.0.1",
    "@octokit/webhooks": "^14.2.0",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.4.2",
    "execa": "^9.6.1",
    "express": "^5.2.1",
    "openai": "^6.42.0",
    "pino": "^9.14.0",
    "pino-pretty": "^11.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^20.19.43",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
